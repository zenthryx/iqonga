# Backend environment – copy to .env and set your values.
# Never commit .env to Git (it contains secrets).

NODE_ENV=development
PORT=3001

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/iqonga
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379

# JWT (required)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# URLs – use your public URL in production (no port if behind reverse proxy)
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
PUBLIC_BASE_URL=http://localhost:5173

# Email / magic-code login (optional – if unset, code is returned in API response)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_SENDER=your-email@example.com

# AI providers (optional – add keys for features you use)
# OPENAI_API_KEY=sk-your-openai-key
# GEMINI_API_KEY=your-gemini-key
# XAI_API_KEY=your-xai-key

# Twitter (optional)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# TWITTER_BEARER_TOKEN=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_CALLBACK_URL=http://localhost:3001/api/twitter/callback

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
# TELEGRAM_ENCRYPTION_KEY=your-32-char-encryption-key

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/auth/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/api/calendar/auth/callback

# Other (optional)
# ENCRYPTION_KEY=your-32-byte-hex-key
# SENTRY_DSN=
# MAX_FILE_SIZE=10485760
# UPLOAD_PATH=./uploads
