# Production Environment Configuration
REACT_APP_API_URL=https://www.iqonga.org/api
REACT_APP_ENVIRONMENT=production

# Solana Mainnet Configuration
REACT_APP_SOLANA_CLUSTER=mainnet-beta
REACT_APP_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
REACT_APP_SOLANA_NETWORK=mainnet

# Platform Configuration
REACT_APP_DOMAIN=iqonga.org
REACT_APP_PLATFORM_NAME=Iqonga

# Payment Configuration (SOL-based)
REACT_APP_AGENT_CREATION_COST=0.1
REACT_APP_PREMIUM_SUBSCRIPTION_COST=0.05
REACT_APP_PLATFORM_CONNECTION_COST=0.02

# Platform Treasury Wallet (Replace with your actual wallet)
REACT_APP_PLATFORM_WALLET=11111111111111111111111111111112

# Feature Flags
REACT_APP_ENABLE_PAYMENTS=true
REACT_APP_ENABLE_MAINNET=true
REACT_APP_ENABLE_WALLET_AUTH=true

# Analytics & Monitoring
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_DEBUG=false 